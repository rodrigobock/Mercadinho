                        "url": {
                            "raw": "{{baseUrl}}/HomeController",
                            "host": ["{{baseUrl}}"],
                            "path": ["HomeController"]
                        },
                        "description": "Remove a sessão e o cookie de login, redirecionando para login.jsp."
                    }
                }
            ]
